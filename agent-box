#!/usr/bin/env bash
set -euo pipefail

USER_NAME="$(id -un)"
SHARE_DIR="${HOME}/.local/share/agent-box"

# Derive a tag-safe slug from an image reference (e.g. "myrepo/dev:1.0" → "myrepo-dev-1-0")
image_slug() {
    printf '%s' "$1" | tr -cs 'a-zA-Z0-9' '-' | sed 's/^-//;s/-$//'
}

usage() {
    cat <<EOF
Usage: agent-box TOOL [OPTIONS] [-- TOOL_ARGS...]
       agent-box init

Run TOOL in an isolated container, mounting the current directory
(or the directory given by -C) as the workspace.

The container image is built automatically on first run.
Available tools correspond to subdirectories of ~/.local/share/agent-box/.

Commands:
  init    Write .config/agent-box.conf in the current directory with the
          default configuration. Errors if the file already exists.

Options:
  -C, --directory DIR        Change to DIR before doing anything
  -b, --base-image IMAGE     Base image to layer the tool on top of
                             (default: node:lts-slim). Must be
                             Debian/Ubuntu (apt-get) or RHEL/Fedora/UBI (dnf)
                             compatible. Each distinct base image gets its own
                             cached image.
  --rebuild                  Rebuild the container image from scratch (--no-cache)
  -h, --help                 Show this help message

Any arguments after -- are passed directly to the tool inside the container.
EOF
    exit "${1:-0}"
}

# ---------------------------------------------------------------------------
# Global flags handled before tool selection
# ---------------------------------------------------------------------------
[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && usage 0

# ---------------------------------------------------------------------------
# init command (tool-agnostic)
# ---------------------------------------------------------------------------
if [[ "${1:-}" == "init" ]]; then
    shift
    if [[ $# -gt 0 ]]; then
        echo "agent-box: 'init' does not accept arguments" >&2
        usage 1
    fi
    CONF_FILE=".config/agent-box.conf"
    if [[ -f "$CONF_FILE" ]]; then
        echo "agent-box: '${PWD}/${CONF_FILE}' already exists; delete it to reinitialize" >&2
        exit 1
    fi
    mkdir -p .config
    cat > "$CONF_FILE" <<'EOF'
# agent-box configuration
# Sourced before CLI argument parsing; CLI flags take precedence.

# Base image to layer each tool on top of.
# Must be Debian/Ubuntu (apt-get) or RHEL/Fedora/UBI (dnf) compatible.
# Each distinct base image gets its own cached container image.
BASE_IMAGE="node:lts-slim"
EOF
    echo "agent-box: created ${PWD}/${CONF_FILE}" >&2
    exit 0
fi

# ---------------------------------------------------------------------------
# Tool selection
# ---------------------------------------------------------------------------
if [[ $# -eq 0 ]]; then
    echo "agent-box: no tool specified" >&2
    usage 1
fi

TOOL="$1"
shift

LIB="${SHARE_DIR}/${TOOL}/lib.sh"
if [[ ! -f "$LIB" ]]; then
    echo "agent-box: unknown tool '${TOOL}' (${LIB} not found)" >&2
    exit 1
fi

# Provide no-op defaults so lib.sh only needs to define what it uses.
get_extra_mounts() { :; }
get_extra_env() { :; }

# shellcheck source=/dev/null
source "$LIB"

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
BASE_IMAGE="node:lts-slim"

# shellcheck source=/dev/null
[[ -f "${HOME}/.config/agent-box.conf" ]] && source "${HOME}/.config/agent-box.conf"

# ---------------------------------------------------------------------------
# Argument parsing
# -C/--directory is handled immediately so the local config is loaded from
# the right place. Other config-affecting flags are saved as CLI_* overrides
# and applied after the local config is sourced.
# ---------------------------------------------------------------------------
REBUILD=false
TOOL_ARGS=()
CLI_BASE_IMAGE=""

while [[ $# -gt 0 ]]; do
    case $1 in
        -C|--directory)
            if [[ -z "${2:-}" ]]; then
                echo "agent-box: --directory requires an argument" >&2
                usage 1
            fi
            cd "$2"
            shift 2
            ;;
        --base-image|-b)
            if [[ -z "${2:-}" ]]; then
                echo "agent-box: --base-image requires an argument" >&2
                usage 1
            fi
            CLI_BASE_IMAGE="$2"
            shift 2
            ;;
        --rebuild)
            REBUILD=true
            shift
            ;;
        -h|--help)
            usage 0
            ;;
        --)
            shift
            TOOL_ARGS=("$@")
            break
            ;;
        -*)
            echo "agent-box: unknown option: $1" >&2
            usage 1
            ;;
        *)
            echo "agent-box: unexpected argument: $1" >&2
            usage 1
            ;;
    esac
done

# shellcheck source=/dev/null
[[ -f ".config/agent-box.conf" ]] && source ".config/agent-box.conf"

[[ -n "$CLI_BASE_IMAGE" ]] && BASE_IMAGE="$CLI_BASE_IMAGE"

COMMON_IMAGE_NAME="agent-box-common:uid-$(id -u)-$(image_slug "$BASE_IMAGE")"
IMAGE_NAME="${IMAGE_PREFIX}:uid-$(id -u)-$(image_slug "$BASE_IMAGE")"

# ---------------------------------------------------------------------------
# Image build
# ---------------------------------------------------------------------------
build_common_image() {
    local -a extra_args=()
    [[ "$REBUILD" == "true" ]] && extra_args+=("--no-cache")

    echo "agent-box: building common image ${COMMON_IMAGE_NAME} ..." >&2
    podman build \
        "${extra_args[@]}" \
        --build-arg BASE_IMAGE="$BASE_IMAGE" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        --build-arg USER_NAME="$USER_NAME" \
        -f "${SHARE_DIR}/Dockerfile.common" \
        -t "$COMMON_IMAGE_NAME" \
        "$SHARE_DIR"
}

build_tool_image() {
    local -a extra_args=()
    [[ "$REBUILD" == "true" ]] && extra_args+=("--no-cache")

    echo "agent-box: building ${TOOL} image ${IMAGE_NAME} ..." >&2
    podman build \
        "${extra_args[@]}" \
        --build-arg COMMON_IMAGE="$COMMON_IMAGE_NAME" \
        --build-arg USER_NAME="$USER_NAME" \
        -f "${SHARE_DIR}/${TOOL}/Dockerfile" \
        -t "$IMAGE_NAME" \
        "${SHARE_DIR}/${TOOL}"
}

if [[ "$REBUILD" == "true" ]]; then
    build_common_image
    build_tool_image
elif ! podman image exists "$COMMON_IMAGE_NAME" 2>/dev/null; then
    build_common_image
    build_tool_image
elif ! podman image exists "$IMAGE_NAME" 2>/dev/null; then
    build_tool_image
fi

# ---------------------------------------------------------------------------
# Tool-specific pre-run setup and mounts
# get_extra_mounts and get_extra_env are defined in lib.sh (or are no-ops).
# They append flags to EXTRA_MOUNTS and EXTRA_ENV respectively, and may
# perform pre-run setup (e.g. creating host directories before mounting).
# ---------------------------------------------------------------------------
EXTRA_MOUNTS=()
EXTRA_ENV=()
get_extra_mounts
get_extra_env

# ---------------------------------------------------------------------------
# Git config mounts (read-only)
# System gitconfig (/etc/gitconfig) is not relabelled (:z omitted) to avoid
# permanently changing SELinux labels on shared system files.
# ---------------------------------------------------------------------------
GIT_CONFIG_MOUNTS=()
[[ -f "${HOME}/.gitconfig" ]] && \
    GIT_CONFIG_MOUNTS+=(-v "${HOME}/.gitconfig:/home/${USER_NAME}/.gitconfig:ro,z")
[[ -d "${HOME}/.config/git" ]] && \
    GIT_CONFIG_MOUNTS+=(-v "${HOME}/.config/git:/home/${USER_NAME}/.config/git:ro,z")
[[ -f "/etc/gitconfig" ]] && \
    GIT_CONFIG_MOUNTS+=(-v "/etc/gitconfig:/etc/gitconfig:ro")

# ---------------------------------------------------------------------------
# Environment variables forwarded to the container
# ---------------------------------------------------------------------------
FORWARDED_ENV=()
[[ -n "${EDITOR:-}" ]] && FORWARDED_ENV+=(--env "EDITOR=${EDITOR}")

# ---------------------------------------------------------------------------
# Run
#
# --userns=keep-id   maps the host UID:GID to the same UID:GID inside the
#                    container, which is what the Dockerfile user was built
#                    with. This avoids root inside the container and ensures
#                    bind-mounted files are readable/writable without chown.
#
# :z on each volume  adds the 'container_file_t' SELinux label so the
#                    container process is allowed to access the files.
#                    Lower-case :z marks the label as shared (safe for home
#                    directory contents that may be accessed by other
#                    confined processes). Use :Z (private) only on
#                    directories that are exclusively owned by this
#                    container.
# ---------------------------------------------------------------------------
exec podman run \
    --rm \
    --interactive \
    --tty \
    --userns=keep-id \
    -v "${PWD}:/workspace:z" \
    "${EXTRA_MOUNTS[@]+"${EXTRA_MOUNTS[@]}"}" \
    "${GIT_CONFIG_MOUNTS[@]+"${GIT_CONFIG_MOUNTS[@]}"}" \
    "${EXTRA_ENV[@]+"${EXTRA_ENV[@]}"}" \
    "${FORWARDED_ENV[@]+"${FORWARDED_ENV[@]}"}" \
    "$IMAGE_NAME" \
    "${TOOL_ARGS[@]+"${TOOL_ARGS[@]}"}"
