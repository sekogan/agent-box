#!/usr/bin/env bash
set -euo pipefail

USER_NAME="$(id -un)"
SHARE_DIR="${HOME}/.local/share/agent-box"

# Derive a tag-safe slug from an image reference (e.g. "myrepo/dev:1.0" → "myrepo-dev-1-0")
image_slug() {
    printf '%s' "$1" | tr -cs 'a-zA-Z0-9' '-' | sed 's/^-//;s/-$//'
}

usage() {
    cat <<EOF
Usage: copilot-box [OPTIONS] [COMMAND] [-- COPILOT_ARGS...]

Launch GitHub Copilot CLI in an isolated container, mounting the current
directory (or the directory given by -C) as the workspace.

The container image is built automatically on first run.
~/.copilot is mounted so Copilot retains its authentication and
configuration across invocations.

Commands:
  init    Write .config/copilot-box.conf in the current directory with the
          current effective configuration (from ~/.config/copilot-box.conf
          and CLI flags). Errors if the file already exists.

Options:
  -C, --directory DIR        Change to DIR before doing anything
  -b, --base-image IMAGE     Base image to layer Copilot CLI on top of
                             (default: node:lts-slim). Must be
                             Debian/Ubuntu (apt-get) or RHEL/Fedora/UBI (dnf)
                             compatible. Each distinct base image gets its own
                             cached image.
  --rebuild                  Rebuild the container image from scratch (--no-cache)
  -h, --help                 Show this help message

Any arguments after -- are passed directly to the copilot command inside
the container (e.g. copilot-box -- --no-color).
EOF
    exit "${1:-0}"
}

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
BASE_IMAGE="node:lts-slim"

# shellcheck source=/dev/null
[[ -f "${HOME}/.config/copilot-box.conf" ]] && source "${HOME}/.config/copilot-box.conf"

# ---------------------------------------------------------------------------
# Argument parsing
# -C/--directory is handled immediately so the local config is loaded from
# the right place. Other config-affecting flags are saved as CLI_* overrides
# and applied after the local config is sourced.
# ---------------------------------------------------------------------------
REBUILD=false
COMMAND=""
COPILOT_ARGS=()
CLI_BASE_IMAGE=""

while [[ $# -gt 0 ]]; do
    case $1 in
        -C|--directory)
            if [[ -z "${2:-}" ]]; then
                echo "copilot-box: --directory requires an argument" >&2
                usage 1
            fi
            cd "$2"
            shift 2
            ;;
        --base-image|-b)
            if [[ -z "${2:-}" ]]; then
                echo "copilot-box: --base-image requires an argument" >&2
                usage 1
            fi
            CLI_BASE_IMAGE="$2"
            shift 2
            ;;
        --rebuild)
            REBUILD=true
            shift
            ;;
        -h|--help)
            usage 0
            ;;
        --)
            shift
            COPILOT_ARGS=("$@")
            break
            ;;
        -*)
            echo "copilot-box: unknown option: $1" >&2
            usage 1
            ;;
        *)
            if [[ -n "$COMMAND" ]]; then
                echo "copilot-box: unexpected argument: $1" >&2
                usage 1
            fi
            COMMAND="$1"
            shift
            ;;
    esac
done

# shellcheck source=/dev/null
[[ -f ".config/copilot-box.conf" ]] && source ".config/copilot-box.conf"

[[ -n "$CLI_BASE_IMAGE" ]] && BASE_IMAGE="$CLI_BASE_IMAGE"

# ---------------------------------------------------------------------------
# init command
# ---------------------------------------------------------------------------
if [[ "$COMMAND" == "init" ]]; then
    if [[ ${#COPILOT_ARGS[@]} -gt 0 ]]; then
        echo "copilot-box: 'init' does not accept -- arguments" >&2
        usage 1
    fi
    CONF_FILE=".config/copilot-box.conf"
    if [[ -f "$CONF_FILE" ]]; then
        echo "copilot-box: '${PWD}/${CONF_FILE}' already exists; delete it to reinitialize" >&2
        exit 1
    fi
    mkdir -p .config
    cat > "$CONF_FILE" <<EOF
# copilot-box configuration
# Sourced before CLI argument parsing; CLI flags take precedence.

# Base image to layer Copilot CLI on top of.
# Must be Debian/Ubuntu (apt-get) or RHEL/Fedora/UBI (dnf) compatible.
# Each distinct base image gets its own cached container image.
BASE_IMAGE="${BASE_IMAGE}"
EOF
    echo "copilot-box: created ${PWD}/${CONF_FILE}" >&2
    exit 0
fi

if [[ -n "$COMMAND" ]]; then
    echo "copilot-box: unknown command: $COMMAND" >&2
    usage 1
fi

COMMON_IMAGE_NAME="agent-box-common:uid-$(id -u)-$(image_slug "$BASE_IMAGE")"
IMAGE_NAME="copilot-box:uid-$(id -u)-$(image_slug "$BASE_IMAGE")"

# ---------------------------------------------------------------------------
# Image build
# ---------------------------------------------------------------------------
build_common_image() {
    local -a extra_args=()
    [[ "$REBUILD" == "true" ]] && extra_args+=("--no-cache")

    echo "copilot-box: building common image ${COMMON_IMAGE_NAME} ..." >&2
    podman build \
        "${extra_args[@]}" \
        --build-arg BASE_IMAGE="$BASE_IMAGE" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        --build-arg USER_NAME="$USER_NAME" \
        -f "${SHARE_DIR}/Dockerfile.common" \
        -t "$COMMON_IMAGE_NAME" \
        "$SHARE_DIR"
}

build_image() {
    local -a extra_args=()
    [[ "$REBUILD" == "true" ]] && extra_args+=("--no-cache")

    echo "copilot-box: building image ${IMAGE_NAME} ..." >&2
    podman build \
        "${extra_args[@]}" \
        --build-arg COMMON_IMAGE="$COMMON_IMAGE_NAME" \
        --build-arg USER_NAME="$USER_NAME" \
        -f "${SHARE_DIR}/Dockerfile.copilot" \
        -t "$IMAGE_NAME" \
        "$SHARE_DIR"
}

if [[ "$REBUILD" == "true" ]]; then
    build_common_image
    build_image
elif ! podman image exists "$COMMON_IMAGE_NAME" 2>/dev/null; then
    build_common_image
    build_image
elif ! podman image exists "$IMAGE_NAME" 2>/dev/null; then
    build_image
fi

# ---------------------------------------------------------------------------
# Ensure Copilot config path exists on the host before mounting.
# Mounting a non-existent directory causes podman to create it as root.
# ---------------------------------------------------------------------------
mkdir -p "${HOME}/.copilot"

# ---------------------------------------------------------------------------
# Git config mounts (read-only)
# System gitconfig (/etc/gitconfig) is not relabelled (:z omitted) to avoid
# permanently changing SELinux labels on shared system files.
# ---------------------------------------------------------------------------
GIT_CONFIG_MOUNTS=()
[[ -f "${HOME}/.gitconfig" ]] && \
    GIT_CONFIG_MOUNTS+=(-v "${HOME}/.gitconfig:/home/${USER_NAME}/.gitconfig:ro,z")
[[ -d "${HOME}/.config/git" ]] && \
    GIT_CONFIG_MOUNTS+=(-v "${HOME}/.config/git:/home/${USER_NAME}/.config/git:ro,z")
[[ -f "/etc/gitconfig" ]] && \
    GIT_CONFIG_MOUNTS+=(-v "/etc/gitconfig:/etc/gitconfig:ro")

# ---------------------------------------------------------------------------
# Environment variables forwarded to the container
# ---------------------------------------------------------------------------
FORWARDED_ENV=()
[[ -n "${EDITOR:-}" ]] && FORWARDED_ENV+=(--env "EDITOR=${EDITOR}")

# ---------------------------------------------------------------------------
# Run
#
# --userns=keep-id   maps the host UID:GID to the same UID:GID inside the
#                    container, which is what the Dockerfile user was built
#                    with. This avoids root inside the container and ensures
#                    bind-mounted files are readable/writable without chown.
#
# :z on each volume  adds the 'container_file_t' SELinux label so the
#                    container process is allowed to access the files.
#                    Lower-case :z marks the label as shared (safe for home
#                    directory contents that may be accessed by other
#                    confined processes). Use :Z (private) only on
#                    directories that are exclusively owned by this
#                    container.
# ---------------------------------------------------------------------------
exec podman run \
    --rm \
    --interactive \
    --tty \
    --userns=keep-id \
    -v "${PWD}:/workspace:z" \
    -v "${HOME}/.copilot:/home/${USER_NAME}/.copilot:z" \
    "${GIT_CONFIG_MOUNTS[@]+"${GIT_CONFIG_MOUNTS[@]}"}" \
    "${FORWARDED_ENV[@]+"${FORWARDED_ENV[@]}"}" \
    "$IMAGE_NAME" \
    "${COPILOT_ARGS[@]+"${COPILOT_ARGS[@]}"}"
